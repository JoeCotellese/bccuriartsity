{# ABOUTME: Base HTML layout — fonts, Pico stylesheet, sticky nav, footer. #}
{# ABOUTME: Wraps every page; each page's sections are injected via {{ content }}. #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">

  {# Favicon — SVG for modern browsers, PNG fallback. #}
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/images/favicon-32.png" sizes="32x32">
  <link rel="apple-touch-icon" href="/images/favicon-180.png">

  {# Open Graph / Twitter — link previews when shared. Absolute once site.url is set. #}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/images/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.name }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/images/og-image.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital@0;1&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="/css/style.css">
  {# Structured data for search engines — driven entirely from _data/site.json. #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": {{ site.name | dump | safe }},
    "description": {{ site.description | dump | safe }},
    "telephone": {{ site.phone | dump | safe }},
    "email": {{ site.email | dump | safe }},
    "address": {
      "@type": "PostalAddress",
      "streetAddress": {{ site.address.street | dump | safe }},
      "addressLocality": {{ site.address.city | dump | safe }},
      "addressRegion": {{ site.address.state | dump | safe }},
      "postalCode": {{ site.address.zip | dump | safe }},
      "addressCountry": "US"
    },
    "openingHoursSpecification": [
      {%- for spec in site.hoursSchema %}
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": {{ spec.days | dump | safe }},
        "opens": {{ spec.opens | dump | safe }},
        "closes": {{ spec.closes | dump | safe }}
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ],
    "sameAs": [
      {%- for key, url in site.social %}
      {{ url | dump | safe }}{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
  </script>
</head>
<body>
  <header class="nav-bar">
    <div class="container">
      <a class="nav-logo" href="/#home">Bucks County <span>CuriARTsity</span></a>
      <nav>
        <ul class="nav-links">
          <li><a href="/#home">Home</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#gallery">Gallery</a></li>
          <li><a href="/#contact">Find Me</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container">
      <span class="footer-logo">{{ site.name }}</span>
      <nav>
        <ul class="nav-links">
          <li><a href="/#home">Home</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#gallery">Gallery</a></li>
          <li><a href="/#contact">Find Me</a></li>
        </ul>
      </nav>
      <span>&copy; {{ "" | currentYear }} {{ site.name }}</span>
    </div>
  </footer>
</body>
</html>
