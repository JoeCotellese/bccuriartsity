{# ABOUTME: Detail page layout for a single gallery piece. #}
{# ABOUTME: Frontmatter (title, medium, year, sold, image) sets the header; the markdown body is the description. #}
---
layout: base.njk
---

<section>
  <div class="container">
    <article class="lot-detail">
      <a class="backlink" href="/#gallery">&larr; Back to the Collection</a>
      <p class="section-label">{{ medium }}{% if year %} · {{ year }}{% endif %}{% if sold %} · Sold{% endif %}</p>
      <h1>{{ title }}</h1>
      {% if image %}<img class="lot-detail__img" src="{{ image }}" alt="{{ title }}">{% endif %}
      {{ content | safe }}
    </article>
  </div>
</section>
