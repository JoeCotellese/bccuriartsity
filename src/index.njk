---
layout: base.njk
---
{# ABOUTME: Home page — single-page layout: hero, about, gallery (from collection), contact. #}
{# Prose copy lives in src/sections/*.md; edit there, not here. #}
{% set hero = collections.section | section("hero") %}
{% set about = collections.section | section("about") %}

<section id="home">
  <div class="container">
    <div class="hero">
      <div>
        <p class="section-label">{{ hero.data.label }}</p>
        <h1>{{ hero.data.headline }}</h1>
        {{ hero.templateContent | safe }}
        <p><a href="{{ hero.data.cta_href }}" role="button">{{ hero.data.cta_text }}</a></p>
      </div>
      <div class="hero-media">
        <span>Featured piece</span>
      </div>
    </div>
  </div>
</section>

<section id="about">
  <div class="container">
    <p class="section-label">{{ about.data.label }}</p>
    <h2>{{ about.data.heading }}</h2>
    {{ about.templateContent | safe }}
  </div>
</section>

<section id="gallery">
  <div class="container">
    <p class="section-label">Collection</p>
    <h2>Featured Pieces</h2>
    {% if collections.gallery | length %}
    <div class="gallery-grid">
      {%- for item in collections.gallery | reverse %}
      <a class="gallery-item" href="{{ item.url }}">
        {% if item.data.image %}
          <img src="{{ item.data.image }}" alt="{{ item.data.title }}" loading="lazy">
        {% else %}
          <span class="gallery-item__placeholder">{{ item.data.title }}</span>
        {% endif %}
        {% if item.data.sold %}<span class="gallery-item__sold">Sold</span>{% endif %}
      </a>
      {%- endfor %}
    </div>
    {% else %}
    <p>The catalogue is being photographed. Check back soon.</p>
    {% endif %}
  </div>
</section>
